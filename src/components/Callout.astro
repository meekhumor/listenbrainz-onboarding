---
// Callout.astro
// Usage in MDX:
//   <Callout type="note">This is a note.</Callout>
//   <Callout type="warning" title="Watch out">Be careful here.</Callout>
// Types: note | tip | warning | important | caution

const { type = "note", title } = Astro.props;

const iconMap = {
  note:      "ℹ",
  tip:       "💡",
  warning:   "⚠",
  important: "◆",
  caution:   "✕",
};

const labelMap = {
  note:      "Note",
  tip:       "Tip",
  warning:   "Warning",
  important: "Important",
  caution:   "Caution",
};

const icon  = iconMap[type]  ?? "ℹ";
const label = title ?? labelMap[type] ?? "Note";
---

<div class={`callout ${type}`} role="note">
  <span class="callout-icon" aria-hidden="true">{icon}</span>
  <div class="callout-content">
    <strong style="display:block; margin-bottom: 0.2rem; font-size: 0.8125rem; text-transform: uppercase; letter-spacing: 0.05em;">{label}</strong>
    <slot />
  </div>
</div>
